# Server Configuration
PORT=5000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/marvels-ecommerce
# or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/marvels-ecommerce

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Shiprocket Integration
SHIPROCKET_EMAIL=your-shiprocket-email@gmail.com
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_PICKUP_LOCATION=Primary

# Email Configuration (Gmail SMTP)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASS=your-16-char-app-password
NOTIFY_EMAIL=admin@marvels-fashion.com
ADMIN_EMAIL=admin@marvels-fashion.com
ADMIN_EMAIL_CC=manager@marvels-fashion.com

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (for CORS and redirects)
CLIENT_URL=https://marvel-kids.vercel.app
FRONTEND_URL=http://localhost:3000